{
  "name": "group-wiki-template",
  "version": "0.2.0",
  "description": "可复用的课题组共读 Wiki 模板（AI / 大模型方向友好）。GitHub 点 Use this template 后 pnpm init:group 一键改为你的组。当前内置 Leon's Group 作为 live demo。",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=22.12"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "pnpm build:index && astro build",
    "build:index": "node scripts/build-index.mjs",
    "context:for": "node scripts/context-for.mjs",
    "migrate:paper-concepts": "node scripts/migrate-paper-concepts.mjs",
    "preview": "astro preview",
    "astro": "astro",
    "new:session": "node scripts/new-session.mjs",
    "new:paper": "node scripts/new-paper.mjs",
    "new:member": "node scripts/new-member.mjs",
    "new:theme": "node scripts/new-theme.mjs",
    "new:concept": "node scripts/new-concept.mjs",
    "new:faq": "node scripts/new-faq.mjs",
    "init:group": "node scripts/init-group.mjs",
    "update:group-config": "node scripts/update-group-config.mjs",
    "smoke-test:fork": "node scripts/smoke-test-fork.mjs",
    "verify": "node scripts/verify.mjs",
    "verify:full": "node scripts/verify.mjs --build",
    "staleness-report": "node scripts/staleness-report.mjs",
    "audit:touchpoints": "node scripts/audit-touchpoints.mjs",
    "list:members": "node scripts/list.mjs members",
    "list:themes": "node scripts/list.mjs themes",
    "list:sessions": "node scripts/list.mjs sessions",
    "list:papers": "node scripts/list.mjs papers",
    "list:concepts": "node scripts/list.mjs concepts",
    "list:faq": "node scripts/list.mjs faq",
    "loop": "bash scripts/ralph/loop.sh",
    "loop:dry": "bash scripts/ralph/loop.sh --dry-run"
  },
  "packageManager": "pnpm@10.33.0",
  "dependencies": {
    "@astrojs/starlight": "^0.38.5",
    "astro": "^6.2.2",
    "katex": "^0.16.45",
    "mermaid": "^11.14.0",
    "rehype-katex": "^7.0.1",
    "remark-math": "^6.0.0",
    "sharp": "^0.34.5",
    "starlight-giscus": "^0.9.1"
  },
  "devDependencies": {
    "unist-util-visit": "^5.1.0"
  }
}
